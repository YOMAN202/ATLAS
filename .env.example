# Copy this file to .env and fill in real values for local development.
# .env is git-ignored (SEC-4) — never commit real credentials.

# --- MySQL server ---
MYSQL_ROOT_PASSWORD=changeme_root

# --- Application DB roles (SEC-3 wires these fully in Phase 6; placeholders for now) ---
# atlas_app:       RW on atlas_oltp only
# atlas_etl:       R on atlas_oltp, RW on atlas_olap
# atlas_reporting: R on atlas_olap only (API dashboard reads + Power BI)

# --- Backend ---
ENVIRONMENT=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

MYSQL_HOST=mysql
MYSQL_PORT=3306
OLTP_SCHEMA=atlas_oltp
OLAP_SCHEMA=atlas_olap

# SQLAlchemy connection URLs (ADR-001: one instance, two schemas)
DATABASE_URL_OLTP=mysql+pymysql://root:changeme_root@mysql:3306/atlas_oltp
DATABASE_URL_OLAP=mysql+pymysql://root:changeme_root@mysql:3306/atlas_olap

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
